# RemService Planner — Environment Configuration

# ── Frontend ──
# HTTP_PORT — порт для доступа к фронтенду (по умолчанию 80)
HTTP_PORT=80

# ── Backend ──
# REMSERVICE_APP_NAME — название приложения
REMSERVICE_APP_NAME=РемСервис-Планировщик

# REMSERVICE_DATABASE_URL — строка подключения к БД
REMSERVICE_DATABASE_URL=sqlite+aiosqlite:///./data.db

# REMSERVICE_DEBUG — режим отладки (true/false)
REMSERVICE_DEBUG=false

# ── OSRM (маршрутизация, опционально) ──
# REMSERVICE_OSRM_BASE_URL=https://router.project-osrm.org/route/v1/driving
# REMSERVICE_OSRM_TIMEOUT=5.0
# REMSERVICE_OSRM_ENABLED=true
